### 更新任务 - 批量修改多个字段
PUT {{baseUrl}}/api/tasks/{{testTaskId}}
Content-Type: application/json

{
  "name": "批量更新测试任务",
  "description": "测试批量更新多个字段",
  "executablePath": "C:\\batch\\update.bat",
  "arguments": "--batch --test",
  "triggerType": "monthly",
  "startTime": "23:59",
  "enabled": true
}

> {%
  client.test("状态码应为 200 或 404", () => {
    client.assert(response.status === 200 || response.status === 404, "状态码应为 200 或 404");
  });
  client.test("如果任务存在，所有字段应已更新", () => {
    if (response.status === 200) {
      client.assert(response.body.name === "批量更新测试任务", "名称应已更新");
      client.assert(response.body.description === "测试批量更新多个字段", "描述应已更新");
      client.assert(response.body.executablePath === "C:\\batch\\update.bat", "可执行路径应已更新");
      client.assert(response.body.arguments === "--batch --test", "参数应已更新");
      client.assert(response.body.triggerType === "monthly", "触发类型应已更新");
      client.assert(response.body.startTime === "23:59", "启动时间应已更新");
      client.assert(response.body.enabled === true, "启用状态应已更新");
    }
  });
%}

### 更新任务 - 清空可选字段（描述）
