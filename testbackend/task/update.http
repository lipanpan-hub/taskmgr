### 错误测试 - 更新不存在的任务
PUT {{baseUrl}}/api/tasks/99999
Content-Type: application/json

{
  "name": "不存在的任务"
}

> {%
  client.test("状态码应为 404", () => {
    client.assert(response.status === 404, "状态码应为 404");
  });
  client.test("应返回错误信息", () => {
    client.assert(response.body.error === "任务不存在", "应返回任务不存在错误");
  });
%}

### 错误测试 - 无效的任务ID（非数字）
PUT {{baseUrl}}/api/tasks/invalid_id
Content-Type: application/json

{
  "name": "测试任务"
}

> {%
  client.test("状态码应为 400", () => {
    client.assert(response.status === 400, "状态码应为 400");
  });
  client.test("应返回错误信息", () => {
    client.assert(response.body.error === "无效的任务ID", "应返回无效的任务ID错误");
  });
%}

### 错误测试 - 空请求体
PUT {{baseUrl}}/api/tasks/1
Content-Type: application/json

{}

> {%
  client.test("状态码应为 200 或 404", () => {
    client.assert(response.status === 200 || response.status === 404, "状态码应为 200 或 404");
  });
  client.test("如果任务存在，应返回任务但不做修改", () => {
    if (response.status === 200) {
      client.assert(response.body.id !== undefined, "应返回任务对象");
    }
  });
%}

### 更新任务 - 修改为 PowerShell 脚本
PUT {{baseUrl}}/api/tasks/{{testTaskId}}
Content-Type: application/json

{
  "name": "PowerShell 监控任务",
  "executablePath": "powershell.exe",
  "arguments": "-ExecutionPolicy Bypass -File C:\\scripts\\monitor.ps1"
}

> {%
  client.test("状态码应为 200 或 404", () => {
    client.assert(response.status === 200 || response.status === 404, "状态码应为 200 或 404");
  });
  client.test("如果任务存在，应更新为 PowerShell 脚本", () => {
    if (response.status === 200) {
      client.assert(response.body.executablePath === "powershell.exe", "可执行路径应为 powershell.exe");
      client.assert(response.body.arguments.includes("-ExecutionPolicy Bypass"), "参数应包含 ExecutionPolicy");
    }
  });
%}

