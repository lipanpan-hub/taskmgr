@baseUrl = {{$dotenv BASE_URL}}

### 准备测试 - 创建一个测试任务
POST {{baseUrl}}/api/tasks
Content-Type: application/json

{
  "name": "更新测试任务",
  "description": "用于测试更新功能的任务",
  "executablePath": "C:\\test\\update-test.bat",
  "arguments": "--test",
  "triggerType": "daily",
  "startTime": "10:00",
  "enabled": true
}

> {%
  client.test("创建任务成功", () => {
    client.assert(response.status === 201, "状态码应为 201");
    client.assert(response.body.id !== undefined, "应返回任务ID");
  });
  
  // 保存任务ID到环境变量供后续测试使用
  if (response.status === 201 && response.body.id) {
    client.global.set("testTaskId", response.body.id);
    client.log("已创建测试任务，ID: " + response.body.id);
  }
%}

### 更新任务 - 修改名称
PUT {{baseUrl}}/api/tasks/{{testTaskId}}
Content-Type: application/json

{
  "name": "更新后的任务名称"
}

> {%
  client.test("状态码应为 200 或 404", () => {
    client.assert(response.status === 200 || response.status === 404, "状态码应为 200 或 404");
  });
  client.test("如果任务存在，名称应已更新", () => {
    if (response.status === 200) {
      client.assert(response.body.name === "更新后的任务名称", "名称应已更新");
      client.assert(response.body.updatedAt !== undefined, "应包含 updatedAt");
    }
  });
  client.test("如果任务不存在，应返回错误", () => {
    if (response.status === 404) {
      client.assert(response.body.error === "任务不存在", "应返回任务不存在错误");
    }
  });
%}

