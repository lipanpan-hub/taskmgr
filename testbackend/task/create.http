### 创建禁用状态的任务
POST {{baseUrl}}/api/tasks
Content-Type: application/json

{
  "name": "待激活任务",
  "description": "暂时禁用的任务",
  "executablePath": "C:\\tasks\\pending.exe",
  "triggerType": "daily",
  "startTime": "12:00",
  "enabled": false
}

> {%
  client.test("状态码应为 201", () => {
    client.assert(response.status === 201, "状态码应为 201");
  });
  client.test("应该是禁用状态", () => {
    client.assert(response.body.enabled === false, "应该是禁用状态");
  });
%}

### 创建最小字段任务（仅必填字段）
POST {{baseUrl}}/api/tasks
Content-Type: application/json

{
  "name": "简单任务",
  "executablePath": "C:\\simple.bat"
}

> {%
  client.test("状态码应为 201", () => {
    client.assert(response.status === 201, "状态码应为 201");
  });
  client.test("应使用默认触发类型 daily", () => {
    client.assert(response.body.triggerType === "daily", "应使用默认触发类型 daily");
  });
  client.test("应使用默认启动时间 09:00", () => {
    client.assert(response.body.startTime === "09:00", "应使用默认启动时间 09:00");
  });
  client.test("应默认启用", () => {
    client.assert(response.body.enabled === true, "应默认启用");
  });
%}

### 创建带复杂参数的任务
POST {{baseUrl}}/api/tasks
Content-Type: application/json

{
  "name": "数据同步任务",
  "description": "同步数据到远程服务器",
  "executablePath": "C:\\sync\\rsync.exe",
  "arguments": "-avz --delete /source/ user@remote:/dest/",
  "triggerType": "daily",
  "startTime": "02:30"
}

> {%
  client.test("状态码应为 201", () => {
    client.assert(response.status === 201, "状态码应为 201");
  });
  client.test("参数应正确保存", () => {
    client.assert(response.body.arguments === "-avz --delete /source/ user@remote:/dest/", "参数应正确保存");
  });
%}

### 创建 PowerShell 脚本任务
POST {{baseUrl}}/api/tasks
Content-Type: application/json

{
  "name": "系统监控脚本",
  "description": "监控系统资源使用情况",
  "executablePath": "powershell.exe",
  "arguments": "-ExecutionPolicy Bypass -File C:\\scripts\\monitor.ps1",
  "triggerType": "daily",
  "startTime": "00:00"
}

> {%
  client.test("状态码应为 201", () => {
    client.assert(response.status === 201, "状态码应为 201");
  });
  client.test("可执行路径应为 powershell.exe", () => {
    client.assert(response.body.executablePath === "powershell.exe", "可执行路径应为 powershell.exe");
  });
%}

### 错误测试 - 缺少必填字段 name
POST {{baseUrl}}/api/tasks
Content-Type: application/json

{
  "executablePath": "C:\\test.bat"
}

> {%
  client.test("状态码应为 400", () => {
    client.assert(response.status === 400, "状态码应为 400");
  });
  client.test("应返回错误信息", () => {
    client.assert(response.body.error === "缺少必填字段", "应返回错误信息");
  });
%}

