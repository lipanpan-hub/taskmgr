### 错误测试 - 重复的任务名称（需要先创建一个任务）
POST {{baseUrl}}/api/tasks
Content-Type: application/json

{
  "name": "每日备份任务",
  "executablePath": "C:\\duplicate.bat"
}

> {%
  client.test("状态码应为 500", () => {
    client.assert(response.status === 500, "状态码应为 500");
  });
  client.test("应返回错误信息", () => {
    client.assert(response.body.error !== undefined, "应返回错误信息");
  });
%}

### 清理测试数据 - 删除所有测试任务
DELETE {{baseUrl}}/api/tasks

> {%
  client.test("状态码应为 200", () => {
    client.assert(response.status === 200, "状态码应为 200");
  });
  client.test("应返回成功消息", () => {
    client.assert(response.body.message !== undefined, "应返回成功消息");
  });
  client.test("应返回删除的任务数量", () => {
    client.assert(response.body.count !== undefined, "应返回删除的任务数量");
  });
  client.test("应返回删除的任务列表", () => {
    client.assert(Array.isArray(response.body.tasks), "应返回删除的任务列表");
  });
  client.log("已删除 " + response.body.count + " 个测试任务");
%}
