@baseUrl = {{$dotenv BASE_URL}}

### 创建每日任务 - 基本测试
POST {{baseUrl}}/api/tasks
Content-Type: application/json

{
  "name": "每日备份任务",
  "description": "每天早上9点执行数据备份",
  "executablePath": "C:\\backup\\backup.bat",
  "arguments": "--full",
  "triggerType": "daily",
  "startTime": "09:00",
  "enabled": true
}

> {%
  client.test("状态码应为 201", () => {
    client.assert(response.status === 201, "状态码应为 201");
  });
  client.test("返回的任务应包含 id", () => {
    client.assert(response.body.id !== undefined, "应包含 id");
  });
  client.test("任务名称应正确", () => {
    client.assert(response.body.name === "每日备份任务", "任务名称应正确");
  });
  client.test("触发类型应为 daily", () => {
    client.assert(response.body.triggerType === "daily", "触发类型应为 daily");
  });
  client.test("应该是启用状态", () => {
    client.assert(response.body.enabled === true, "应该是启用状态");
  });
%}


