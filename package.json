{
  "name": "@lppx/taskmgr",
  "description": "定时任务管理器",
  "version": "0.1.0",
  "author": "lppx",
  "bin": {
    "tm": "./bin/run.js"
  },
  "bugs": "https://github.com/lipanpan-hub/taskmgr/issues",
  "dependencies": {
    "@oclif/core": "^4",
    "@oclif/plugin-autocomplete": "^3.2.40",
    "@oclif/plugin-help": "^6",
    "@oclif/plugin-not-found": "^3.2.74",
    "@oclif/plugin-version": "^2.2.37",
    "@oclif/plugin-warn-if-update-available": "^3.1.55",
    "edge-js": "^25.0.1"
  },
  "devDependencies": {
    "@eslint/compat": "^1",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/chai": "^4",
    "@types/mocha": "^10",
    "@types/node": "^18",
    "chai": "^4",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "mocha": "^10",
    "oclif": "^4",
    "shx": "^0.3.3",
    "ts-node": "^10",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./Templates",
    "./TaskScheduler.2.12.2",
    "./oclif.manifest.json"
  ],
  "homepage": "https://github.com/lipanpan-hub/taskmgr",
  "keywords": [
    "oclif"
  ],
  "license": "BSL",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "tm",
    "commands": "./dist/commands",
    "hooks": {
      "init": "./dist/hooks/init"
    },
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-autocomplete",
      "@oclif/plugin-not-found",
      "@oclif/plugin-warn-if-update-available",
      "@oclif/plugin-version"
    ],
    "topicSeparator": " ",
    "topics": {
      "tsk": {
        "description": "定时任务管理"
      },
      "scripts": {
        "description": "脚本管理"
      }
    }
  },
  "repository": "lipanpan-hub/taskmgr",
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "lint": "eslint",
    "pack:tarballs": "oclif pack tarballs",
    "pack:win": "oclif pack win",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "npm run lint",
    "prepack": "oclif manifest && oclif readme",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "oclif readme && git add README.md"
  },
  "types": "dist/index.d.ts"
}
