{
  "name": "taskmgr",
  "description": "my taskmgr cli",
  "version": "2.3.6",
  "author": "lppx",
  "bin": {
    "ttt": "./bin/run.js",
    "tm": "./bin/run.js"
  },
  "bugs": "https://github.com/lipanpan-hub/taskmgr/issues",
  "dependencies": {
    "@oclif/core": "^4",
    "@oclif/plugin-autocomplete": "^3.2.40",
    "@oclif/plugin-help": "^6",
    "@oclif/plugin-not-found": "^3.2.74",
    "@oclif/plugin-version": "^2.2.37",
    "@oclif/plugin-warn-if-update-available": "^3.1.55",
    "@oclif/plugin-which": "^3.2.46",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "edge-js": "^25.0.1",
    "express": "^5.2.1",
    "fuse.js": "^7.1.0",
    "prompts": "^2.4.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/compat": "^1",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/chai": "^4",
    "@types/express": "^5.0.6",
    "@types/mocha": "^10",
    "@types/node": "^18",
    "@types/prompts": "^2.4.9",
    "@types/socket.io": "^3.0.1",
    "autoprefixer": "^10.5.0",
    "chai": "^4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "mocha": "^10",
    "oclif": "^4.23.0",
    "postcss": "^8.5.9",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shx": "^0.3.3",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "./bin",
    "./public",
    "./dist",
    "./Templates",
    "./TaskScheduler.2.12.2",
    "./oclif.manifest.json"
  ],
  "homepage": "https://github.com/lipanpan-hub/taskmgr",
  "keywords": [
    "oclif"
  ],
  "license": "BSL",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "tm",
    "dirname": "lppxtaskmgr",
    "binAliases": [
      "ttt"
    ],
    "commands": "./dist/commands",
    "hooks": {
      "init": "./dist/hooks/init"
    },
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-autocomplete",
      "@oclif/plugin-not-found",
      "@oclif/plugin-warn-if-update-available",
      "@oclif/plugin-version"
    ],
    "topicSeparator": " ",
    "topics": {
      "wtsk": {
        "description": "win定时任务管理"
      },
      "scripts": {
        "description": "脚本管理"
      }
    },
    "additionalFiles": [
      "node_modules/edge-js/**/*",
      "node_modules/better-sqlite3/**/*",
      "TaskScheduler.2.12.2/**/*"
    ]
  },
  "repository": "lipanpan-hub/taskmgr",
  "scripts": {
    "start": "node bin/run.js",
    "build": "npm run build:css && shx rm -rf dist tsconfig.tsbuildinfo && tsc -b",
    "build:css": "npx tailwindcss -i ./public/css/input.css -o ./public/css/style.css --minify --content \"./public/**/*.{html,js}\"",
    "watch:css": "npx tailwindcss -i ./public/css/input.css -o ./public/css/style.css --watch --content \"./public/**/*.{html,js}\"",
    "debug": "cross-env DEBUG=* node --inspect bin/dev.js",
    "lint": "eslint",
    "pack:tarballs": "oclif pack tarballs",
    "pack:wintest": "oclif pack win --targets win32-x64",
    "pack:win": "oclif pack win",
    "rebuild:native": "npm rebuild edge-js better-sqlite3",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "npm run lint",
    "prepack": "oclif manifest && oclif readme",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "oclif readme && git add README.md",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "dev": "concurrently \"npm run watch:css\" \"npm run dev:backend\" --names \"CSS,Backend\" --prefix-colors \"cyan,green\"",
    "dev:backend": "tsx watch src/backend/server.ts",
    "start:backend": "node dist/backend/server.js"
  },
  "types": "dist/index.d.ts"
}
